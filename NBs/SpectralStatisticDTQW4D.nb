  RowBox[{
   RowBox[{"dimSpace", "=", 
    RowBox[{"GridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GroverAngle", "=", 
   RowBox[{"Pi", "/", "4."}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S", " ", "=", " ", 
   RowBox[{"BuildShiftOperators", "[", 
    RowBox[{"GridData", ",", " ", 
     RowBox[{"CoinDimension", " ", "->", " ", "4"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"c", " ", "=", " ", 
   RowBox[{"Coin", "[", 
    RowBox[{
     RowBox[{"GeneralizedGroverCoin", "[", 
      RowBox[{"Pi", "/", "4."}], "]"}], ",", " ", "dimSpace"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"EvolutionOp", "=", 
    RowBox[{"S", ".", "c"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Dimensi\[OAcute]n del operador evoluci\[OAcute]n: \>\"", ",", 
   RowBox[{"EvolutionOp", "//", "Length"}]}], "]"}], "\[IndentingNewLine]", 
