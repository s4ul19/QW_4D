Cell[BoxData[{
 RowBox[{
  RowBox[{"L1", "=", "50"}], ";", 
  RowBox[{"R1", "=", "30"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GridData", "=", 
   RowBox[{"GenerateSinaiBasis", "[", 
    RowBox[{"L1", ",", "R1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dimSpace", "=", 
    RowBox[{"GridData", "[", "\"\<Dimension\>\"", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GroverAngle", "=", 
   RowBox[{"Pi", "/", "4."}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S", " ", "=", " ", 
   RowBox[{"BuildShiftOperators", "[", 
    RowBox[{"GridData", ",", " ", 
     RowBox[{"CoinDimension", " ", "->", " ", "4"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"c", " ", "=", " ", 
   RowBox[{"Coin", "[", 
    RowBox[{
     RowBox[{"GeneralizedGroverCoin", "[", 
      RowBox[{"Pi", "/", "4."}], "]"}], ",", " ", "dimSpace"}], "]"}]}], 
  ";"}], "\n", 
