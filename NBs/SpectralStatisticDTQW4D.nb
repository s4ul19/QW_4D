Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"UnfoldedDat", "=", 
   RowBox[{
    RowBox[{"Unfold", "[", 
     RowBox[{"FilteredPhases", "//", "Sort"}], "]"}], 
    "[", "\"\<UnfoldedLevels\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"spacings", "=", 
   RowBox[{"Differences", "[", 
    RowBox[{"UnfoldedDat", ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EnsemblesList", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<Poisson\>\"", ",", "\"\<GOE/COE\>\"", 
     ",", "\"\<GUE/CUE\>\""}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"BetaValues", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "2"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotColors", "=", 
   RowBox[{"{", 
    RowBox[{"Black", ",", "Red", ",", "Blue"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TheoreticalCurves", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"LevelSpacingDistribution", "[", 
         RowBox[{"SVar", ",", "#"}], "]"}], "&"}], "/@", "BetaValues"}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"SVar", ",", "0", ",", "4"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Directive", "[", 
          RowBox[{
           RowBox[{"Thickness", "[", "0.006", "]"}], ",", "#"}], "]"}], "&"}],
         "/@", "PlotColors"}], ")"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"LineLegend", "[", 
         RowBox[{"PlotColors", ",", "EnsemblesList", ",", 
          RowBox[{"LegendFunction", "->", "\"\<Frame\>\""}], ",", 
          RowBox[{"LabelStyle", "->", "16"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0.8", ",", "0.75"}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"  ", 
  RowBox[{
   RowBox[{"EmpiricalHistogram", "=", 
    RowBox[{"Histogram", "[", 
     RowBox[{
     "spacings", ",", " ", "\"\<FreedmanDiaconis\>\"", ",", " ", "\"\<PDF\>\"",
       ",", "  ", "\n", "        ", 
      RowBox[{"PlotRange", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "4"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}]}], ",", " ", "\n", 
      "        ", 
      RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", "\n", "        ", 
      RowBox[{"FrameLabel", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<s\>\"", ",", " ", "\"\<P(s)\>\""}], "}"}]}], ",", "\n", 
      "        ", 
      RowBox[{"ImageSize", "->", "500"}], ",", "\n", "        ", 
      RowBox[{"LabelStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", " ", "24"}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"6.", " ", "Combine", " ", "and", " ", "display"}], "*)"}]}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{"EmpiricalHistogram", ",", "TheoreticalCurves"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
