  RowBox[{"Lx", "=", "20"}], ";", 
  RowBox[{"Ly", "=", "15"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GridData", "=", 
   RowBox[{"GenerateRectangleBasis", "[", 
    RowBox[{"Lx", ",", "Ly"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
