Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tmax", "=", "3"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DimSpace", "=", 
     RowBox[{"Length", "[", "FilteredPhases", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TimeList", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"1", ",", 
       RowBox[{"tmax", "*", "DimSpace"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TauList", "=", 
     RowBox[{"TimeList", "/", "DimSpace"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "C\[AAcute]lculo", " ", "del", " ", "SFF", " ", "Crudo", " ", 
     RowBox[{"(", "Normalizado", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SffRaw", "=", 
     RowBox[{
      RowBox[{"SpectralFormFactor", "[", 
       RowBox[{"FilteredPhases", ",", "TimeList"}], "]"}], "/", 
      "DimSpace"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Suavizado", " ", "\[OAcute]ptimo", " ", "para", " ", "DTQWs", 
     " ", 
     RowBox[{"(", 
      RowBox[{"Ventana", " ", "Par"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"windowSize", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SffSmoothedScaled", "=", 
     RowBox[{"TimeAveragedSFF", "[", 
      RowBox[{"TauList", ",", "SffRaw", ",", "windowSize"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Visualizaci\[OAcute]n", " ", "de", " ", "alta", " ", 
     "calidad", " ", "con", " ", "MaTeX"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"SffSmoothedScaled", ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"All", ",", "Automatic"}], "}"}]}], ",", 
       RowBox[{"Joined", "->", "True"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", "DarkBlue"}], "]"}]}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"MaTeX", "/@", 
         RowBox[{"{", 
          RowBox[{"\"\<\\\\tau = t/N\>\"", ",", "\"\<K(\\\\tau)\>\""}], 
          "}"}]}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{
        "MaTeX", "[", "\"\<\\\\text{Discrete SFF - Bunimovich Stadium}\>\"", 
         "]"}]}], ",", 
       RowBox[{"BaseStyle", "->", 
        RowBox[{"{", 
         RowBox[{"FontFamily", "->", "\"\<Latin Modern Roman\>\""}], 
         "}"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"SpectralFormFactorRMT", "[", 
        RowBox[{"\[Tau]", ",", "1"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Tau]", ",", "0", ",", "tmax"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", "Dashed", ",", "Thick"}], "]"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"All", ",", "Automatic"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"MaTeX", "[", "\"\<\\\\text{GOE}\>\"", "]"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"Right", ",", "Bottom"}], "}"}]}], "]"}]}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.991221430636842*^9, 3.991221430639374*^9}, {
