TraditionalForm], \"errors\" -> {}, \"input\" -> \"\\\\phi\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", ",", " ", "\"\<DOS\>\""}], 
     "}"}]}], ",", 
