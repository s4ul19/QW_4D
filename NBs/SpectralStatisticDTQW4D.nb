   RowBox[{
    RowBox[{"-", "Pi"}], " ", "a", " ", "0"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"FilteredPhases1", "=", " ", 
     RowBox[{"Select", "[", 
