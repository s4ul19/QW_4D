grid data for the full Sinai billiard with semi-side \!\(\*StyleBox[\"L\", \
\"TI\"]\) of the square (total side is 2L), and radius \!\(\*StyleBox[\"R\", \
\"TI\"]\). The keys are: \"Coords\", \"Mapping\" , \"Dimension\" , \
\"Params\", \"Type\".", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, QuantumWalks`Billiards`GenerateFullSinaiBasis, {
      QuantumWalks`Billiards`GenerateFullSinaiBasis[
         Pattern[QuantumWalks`L, 
          Blank[Integer]], 
         Pattern[QuantumWalks`Billiards`Sinai`Private`R, 
          Blank[Integer]]] :> 
       Module[{QuantumWalks`Billiards`Sinai`Private`coords, 
          QuantumWalks`Billiards`Sinai`Private`stateToIndex, 
          QuantumWalks`Billiards`Sinai`Private`validRegionQ}, 
         QuantumWalks`Billiards`Sinai`Private`validRegionQ = 
          Function[{
            QuantumWalks`Billiards`Sinai`Private`x, 
             QuantumWalks`Billiards`Sinai`Private`y}, 
            And[
            Abs[QuantumWalks`Billiards`Sinai`Private`x] <= QuantumWalks`L, 
             Abs[QuantumWalks`Billiards`Sinai`Private`y] <= QuantumWalks`L, 
             QuantumWalks`Billiards`Sinai`Private`x^2 + 
              QuantumWalks`Billiards`Sinai`Private`y^2 >= 
             QuantumWalks`Billiards`Sinai`Private`R^2]]; 
         QuantumWalks`Billiards`Sinai`Private`coords = Select[
            Flatten[
             
             Table[{QuantumWalks`Billiards`Sinai`Private`x, 
               QuantumWalks`Billiards`Sinai`Private`y}, {
              QuantumWalks`Billiards`Sinai`Private`x, -QuantumWalks`L, 
               QuantumWalks`L}, {
              QuantumWalks`Billiards`Sinai`Private`y, -QuantumWalks`L, 
               QuantumWalks`L}], 1], 
            Apply[QuantumWalks`Billiards`Sinai`Private`validRegionQ]]; 
         QuantumWalks`Billiards`Sinai`Private`stateToIndex = 
          AssociationThread[
           QuantumWalks`Billiards`Sinai`Private`coords -> Range[
              Length[QuantumWalks`Billiards`Sinai`Private`coords]]]; <|
          "Coords" -> QuantumWalks`Billiards`Sinai`Private`coords, "Mapping" -> 
           QuantumWalks`Billiards`Sinai`Private`stateToIndex, "Dimension" -> 
           Length[QuantumWalks`Billiards`Sinai`Private`coords], 
           "Params" -> <|
            "L" -> QuantumWalks`L, "R" -> 
