Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"-", "Pi"}], " ", "a", " ", "0"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"FilteredPhases1", "=", " ", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"eigenphases", "//", "Sort"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "Pi"}], "<", "#", "<", 
         RowBox[{"-", "0.001"}]}], "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Histogram", "[", 
    RowBox[{"FilteredPhases1", ",", "Automatic", ",", "\"\<PDF\>\"", ",", 
     RowBox[{"PlotTheme", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Detailed\>\"", ",", "\"\<Frame\>\"", 
        ",", "\"\<SansLabels\>\""}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", "18"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[\"\[Phi]\", \
TraditionalForm], \"errors\" -> {}, \"input\" -> \"\\\\phi\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", ",", " ", "\"\<DOS\>\""}], 
       "}"}]}], ",", 
