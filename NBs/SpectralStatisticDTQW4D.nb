Cell[BoxData[{
 RowBox[{
  RowBox[{"eigenphases", " ", "=", " ", 
   RowBox[{"Sort", "[", 
    RowBox[{"Arg", "[", 
     RowBox[{"Eigenvalues", "[", 
      RowBox[{"Normal", "[", "EvolutionOp", "]"}], "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
